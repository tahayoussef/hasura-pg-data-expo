# copy to .env and change the values; .env is gitignored
POSTGRES_PASSWORD=postgrespassword
HASURA_GRAPHQL_ADMIN_SECRET=myadminsecretkey
EXPORTER_PASSWORD=exporterpassword
# HS256 JWT signing key for consumer-app tokens; must be at least 32 characters
HASURA_JWT_KEY=local-dev-jwt-signing-key-32chars-min!
# Grafana UI login (admin) and the read-only Postgres role Grafana connects with
GRAFANA_ADMIN_PASSWORD=grafana
GRAFANA_READER_PASSWORD=grafanareader
